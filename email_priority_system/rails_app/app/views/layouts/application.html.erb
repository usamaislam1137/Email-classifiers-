<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Email Priority Classification System - ML-powered email triage">
    <title><%= content_for?(:title) ? yield(:title) + " | " : "" %>Email Priority Classifier</title>

    <!-- Bootstrap 5.3 CSS -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
          integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
          crossorigin="anonymous">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Chart.js 4 -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

    <!-- Custom styles -->
    <%= stylesheet_link_tag "application", media: "all" %>

    <!-- Rails importmap -->
    <%= javascript_importmap_tags %>
  </head>

  <body class="d-flex flex-column min-vh-100 bg-light">

    <!-- -- Navigation --------------------------------------------------- -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
      <div class="container">
        <a class="navbar-brand fw-bold" href="<%= root_path %>">
          <i class="bi bi-envelope-check-fill text-primary me-2"></i>
          Email Priority Classifier
        </a>
        <button class="navbar-toggler" type="button"
                data-bs-toggle="collapse" data-bs-target="#mainNav"
                aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNav">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item">
              <%= link_to "Dashboard", dashboard_path, class: "nav-link #{current_page?(dashboard_path) || current_page?(root_path) ? 'active' : ''}" %>
            </li>
            <li class="nav-item">
              <%= link_to "History", classifications_path, class: "nav-link #{current_page?(classifications_path) ? 'active' : ''}" %>
            </li>
          </ul>
          <div class="d-flex">
            <%= link_to new_classification_path,
                        class: "btn btn-primary btn-sm" do %>
              <i class="bi bi-plus-circle me-1"></i> Classify Email
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <!-- -- Flash messages ----------------------------------------------- -->
    <div class="container mt-3">
      <%= render "shared/flash" %>
    </div>

    <!-- -- Main content ------------------------------------------------- -->
    <main class="container flex-grow-1 py-4">
      <%= yield %>
    </main>

    <!-- -- Footer ------------------------------------------------------- -->
    <footer class="bg-dark text-light py-3 mt-auto">
      <div class="container">
        <div class="row align-items-center">
          <div class="col-md-6">
            <small class="text-muted">
              <i class="bi bi-envelope-check-fill text-primary me-1"></i>
              Email Priority Classification System &mdash; Dissertation Project
            </small>
          </div>
          <div class="col-md-6 text-end">
            <small class="text-muted">
              Rails <%= Rails.version %> &middot; Ruby <%= RUBY_VERSION %> &middot;
              <span id="api-status-footer">
                <span class="badge bg-secondary">ML API</span>
              </span>
            </small>
          </div>
        </div>
      </div>
    </footer>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
            crossorigin="anonymous"></script>

    <!-- API status check -->
    <script>
      document.addEventListener("DOMContentLoaded", function() {
        fetch("/health")
          .then(r => r.json())
          .then(data => {
            const el = document.getElementById("api-status-footer");
            if (el) {
              const ok = data.ml_api === true;
              el.innerHTML = ok
                ? '<span class="badge bg-success"><i class="bi bi-circle-fill me-1"></i>ML API Online</span>'
                : '<span class="badge bg-danger"><i class="bi bi-circle-fill me-1"></i>ML API Offline</span>';
            }
          })
          .catch(() => {});
      });
    </script>

    <%= yield :page_scripts %>
  </body>
</html>
